{
  "expo": {
    "name": "TripSwipe",
    "slug": "tripswipe",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.tripswipe"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourname.tripswipe"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "scheme": "tripswipe"
  }
}
